#!/usr/bin/env bash
#
# review-queue — discovery + execution workhorse for the batch PR-review fleet.
#
# Modes:
#   review-queue --list-json     Emit a JSON array of eligible PRs (never runs claude).
#   review-queue --run <url>     Review ONE PR; stream claude's JSON events to stdout.
#   review-queue --verdict <url> Emit my latest review state on a PR as JSON (no claude).
#   review-queue --rate-reset    Emit the epoch when exhausted gh rate limits recover.
#
# Env overrides:
#   CODE_ROOT   local checkout root         (default: $HOME/code)
#   SLASH_CMD   review slash command name   (default: /review-pr)
#
set -euo pipefail

CODE_ROOT="${CODE_ROOT:-$HOME/code}"
SLASH_CMD="${SLASH_CMD:-/review-pr}"

# ---- dependency guard -------------------------------------------------------
for dep in gh jq claude git; do
  command -v "$dep" >/dev/null 2>&1 || {
    echo "review-queue: missing required dependency: $dep" >&2
    exit 127
  }
done

usage() {
  cat >&2 <<'EOF'
usage:
  review-queue --list-json        emit JSON array of eligible PRs (no claude)
  review-queue --run <pr-url>     review one PR, stream JSON events to stdout
  review-queue --verdict <pr-url> emit my latest review state as JSON (no claude)
  review-queue --rate-reset       emit epoch when exhausted gh rate limits recover
EOF
}

# Parse a GitHub PR URL into owner/name/number. Sets globals; exits 2 on mismatch.
parse_pr_url() {
  if [[ ! "$1" =~ ^https://github\.com/([^/]+)/([^/]+)/pull/([0-9]+) ]]; then
    echo "review-queue: not a recognizable GitHub PR URL: $1" >&2
    exit 2
  fi
  P_OWNER="${BASH_REMATCH[1]}"
  P_NAME="${BASH_REMATCH[2]}"
  P_NUM="${BASH_REMATCH[3]}"
  P_REPO="$P_OWNER/$P_NAME"
}

# Ensure a local checkout of $repo exists at $dir, cloning it if missing.
# Returns 0 when the checkout is present (already there or freshly cloned),
# 1 when a required clone failed. Clone progress/errors go to stderr.
ensure_checkout() {
  local repo="$1" dir="$2"
  [[ -d "$dir" ]] && return 0
  echo "review-queue: cloning $repo -> $dir (no local checkout)" >&2
  mkdir -p "$(dirname "$dir")"
  gh repo clone "$repo" "$dir" -- --quiet >&2
}

# Classify a PR's CI status by its status-check rollup. Echoes one of:
#   none      — no checks configured at all (do NOT skip; nothing to gate on)
#   green     — every check completed successfully (SUCCESS/NEUTRAL/SKIPPED)
#   not_green — at least one check is failing, pending, or otherwise not green
# On a gh/jq error we can't classify, so we echo "none" and let the PR through
# rather than skipping a PR we simply failed to inspect.
ci_state() {
  local repo="$1" num="$2"
  gh pr view "$num" --repo "$repo" --json statusCheckRollup --jq '
    .statusCheckRollup as $c
    | if ($c | length) == 0 then "none"
      else
        ( [ $c[] |
            if .__typename == "CheckRun" then
              (.status == "COMPLETED"
               and (.conclusion == "SUCCESS" or .conclusion == "NEUTRAL" or .conclusion == "SKIPPED"))
            elif .__typename == "StatusContext" then
              (.state == "SUCCESS")
            else false end
          ] | if all then "green" else "not_green" end )
      end
  ' 2>/dev/null || echo "none"
}

# ---- re-review gate ---------------------------------------------------------
# Decides whether a PR still needs a review from ME, and *why*.
# Prints a reason token to stdout and returns 0 when eligible; returns 1 otherwise.
#
# Always prints a reason token to stdout; returns 0 if a (re-)review is needed,
# 1 if not. Eligible tokens:
#   never_reviewed                       — I have no review on this PR yet
#   new_commits_since_changes_requested  — I requested changes; head has moved past my review's commit
#   prior_review_not_approved            — my last review was COMMENTED/DISMISSED (re-review)
# Skip tokens:
#   approved                             — my last review APPROVED this head
#   changes_requested_no_new_commits     — I requested changes; head hasn't moved
#
# GitHub review-state reasoning kept verbatim from the supplied gate: compare the
# PR head SHA against the commit_id of my most-recent review, and treat
# never-reviewed distinctly from re-requested.
review_reason() {
  local repo="$1" num="$2" head reviews mystate mycommit
  head=$(gh pr view "$num" --repo "$repo" --json headRefOid --jq .headRefOid)
  reviews=$(gh api "repos/$repo/pulls/$num/reviews" --paginate \
    --jq "[.[] | select(.user.login==\"$ME\")] | sort_by(.submitted_at)")
  [[ "$(echo "$reviews" | jq 'length')" -eq 0 ]] && { echo "never_reviewed"; return 0; }  # never reviewed
  mystate=$(echo "$reviews" | jq -r '.[-1].state')
  mycommit=$(echo "$reviews" | jq -r '.[-1].commit_id')
  case "$mystate" in
    APPROVED)          echo "approved"; return 1 ;;                 # done
    CHANGES_REQUESTED)
      if [[ "$head" != "$mycommit" ]]; then
        echo "new_commits_since_changes_requested"; return 0
      else
        echo "changes_requested_no_new_commits"; return 1
      fi ;;
    *)                 echo "prior_review_not_approved"; return 0 ;; # commented/dismissed
  esac
}

# ---- MODE A: discovery + gating --------------------------------------------
# Emits a single JSON object on stdout:
#   { "eligible": [ {repo,name,number,url,title,reason}, ... ],
#     "skipped":  [ {repo,name,number,url,title,reason}, ... ] }
# Every requested-review PR lands in exactly one bucket. Human diagnostics still
# go to stderr. Never invokes claude.
list_json() {
  ME=$(gh api user --jq .login)

  local prs
  # All open PRs where I'm a requested reviewer.
  prs=$(gh search prs --review-requested=@me --state=open \
    --json repository,number,url,title --limit 100)

  # Each PR is emitted as one compact, _bucket-tagged JSON object; the final jq
  # partitions the stream into the eligible/skipped arrays (empty -> []).
  emit() {  # emit <bucket> <reason>
    jq -nc \
      --arg    bucket "$1" \
      --arg    reason "$2" \
      --arg    repo   "$repo" \
      --arg    name   "$name" \
      --argjson number "$num" \
      --arg    url    "$url" \
      --arg    title  "$title" \
      '{_bucket:$bucket, repo:$repo, name:$name, number:$number, url:$url, title:$title, reason:$reason}'
  }

  echo "$prs" | jq -c '.[]' | while read -r pr; do
    local repo name num url title dir reason
    repo=$(jq -r '.repository.nameWithOwner' <<<"$pr")
    name=$(jq -r '.repository.name'          <<<"$pr")
    num=$(jq  -r '.number'                   <<<"$pr")
    url=$(jq  -r '.url'                       <<<"$pr")
    title=$(jq -r '.title'                    <<<"$pr")

    dir="$CODE_ROOT/$name"
    if ! ensure_checkout "$repo" "$dir"; then
      echo "skip $repo#$num — clone failed" >&2
      emit skipped clone_failed
      continue
    fi

    # CI gate: skip only when a check is actually failing or pending. A PR with
    # no CI configured at all (empty rollup) is left eligible — nothing to gate.
    if [[ "$(ci_state "$repo" "$num")" == "not_green" ]]; then
      echo "skip $repo#$num — CI not green" >&2
      emit skipped ci_not_green
      continue
    fi

    if reason=$(review_reason "$repo" "$num"); then
      emit eligible "$reason"
    else
      echo "skip $repo#$num — already reviewed ($reason)" >&2
      emit skipped "$reason"
    fi
  done | jq -s '{
    eligible: [ .[] | select(._bucket == "eligible") | del(._bucket) ],
    skipped:  [ .[] | select(._bucket == "skipped")  | del(._bucket) ]
  }'
}

# ---- MODE B: run one review -------------------------------------------------
run_one() {
  local url="$1" name num dir
  parse_pr_url "$url"
  name="$P_NAME"
  num="$P_NUM"
  dir="$CODE_ROOT/$name"

  if ! ensure_checkout "$P_REPO" "$dir"; then
    echo "review-queue: no local checkout at $dir for $P_REPO#$num (clone failed)" >&2
    exit 3
  fi

  cd "$dir"
  # Check out the PR head as a DETACHED HEAD, never a persistent local branch.
  # A named `pr-$num` branch would survive past this run (we exec into claude
  # below and never regain control to delete it), so they used to pile up one
  # per review. Detaching leaves nothing behind. We also reap any `pr-*`
  # branches stranded by older versions of this script before fetching: first
  # detach off whatever is checked out (so a current `pr-*` branch is deletable),
  # then delete every `pr-*` head.
  git checkout --quiet --detach 2>/dev/null || true
  git for-each-ref --format='%(refname:short)' 'refs/heads/pr-*' | while read -r b; do
    [ -n "$b" ] && git branch -D "$b" --quiet 2>/dev/null || true
  done
  git fetch origin "pull/$num/head" --quiet 2>/dev/null || true
  git checkout --quiet --detach FETCH_HEAD 2>/dev/null || true

  # exec: claude's stdout becomes this script's stdout (unbuffered passthrough)
  # and claude's exit code becomes ours.
  exec claude -p "$SLASH_CMD $url" \
    --permission-mode auto \
    --output-format stream-json \
    --verbose
}

# ---- MODE C: my latest review verdict on one PR -----------------------------
# Emits {"state": "...", "submitted_at": "..."} for my most-recent review, where
# state is APPROVED | CHANGES_REQUESTED | COMMENTED | DISMISSED | NONE. The app
# calls this after an auto-run to record the posted verdict (ground truth, not a
# transcript guess). Never invokes claude.
verdict_one() {
  parse_pr_url "$1"
  ME=$(gh api user --jq .login)
  local reviews
  reviews=$(gh api "repos/$P_REPO/pulls/$P_NUM/reviews" --paginate \
    --jq "[.[] | select(.user.login==\"$ME\")] | sort_by(.submitted_at)")
  if [[ "$(echo "$reviews" | jq 'length')" -eq 0 ]]; then
    echo '{"state":"NONE","submitted_at":null}'
  else
    echo "$reviews" | jq -c '.[-1] | {state, submitted_at}'
  fi
}

# ---- MODE D: rate-limit recovery time ---------------------------------------
# When a gh call fails with a rate-limit error, the app calls this to learn when
# to resume. Prints the epoch (seconds) at which the *latest* currently-exhausted
# REST resource resets, so resuming then clears every primary limit we hit. Prints
# nothing if no resource shows remaining==0 (e.g. a secondary limit, which the
# rate_limit endpoint doesn't report) — the app then applies its own backoff.
# The rate_limit endpoint does not itself count against any limit.
rate_reset() {
  gh api rate_limit --jq '
    [ .resources | to_entries[] | select(.value.remaining == 0) | .value.reset ]
    | if length > 0 then max else empty end
  ' 2>/dev/null || true
}

# ---- dispatch ---------------------------------------------------------------
case "${1:-}" in
  --list-json)
    [[ $# -eq 1 ]] || { usage; exit 2; }
    list_json
    ;;
  --run)
    [[ $# -eq 2 ]] || { usage; exit 2; }
    run_one "$2"
    ;;
  --verdict)
    [[ $# -eq 2 ]] || { usage; exit 2; }
    verdict_one "$2"
    ;;
  --rate-reset)
    [[ $# -eq 1 ]] || { usage; exit 2; }
    rate_reset
    ;;
  -h|--help)
    usage
    ;;
  *)
    usage
    exit 2
    ;;
esac
